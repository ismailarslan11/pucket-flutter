PORT=8080
# Kalıcı veritabanı (Render PostgreSQL veya yerel Postgres)
# DATABASE_URL=postgres://user:pass@host:5432/pucket
# Yerel Postgres SSL kapalıysa:
# PGSSL=false
# Opsiyonel: Firebase Admin JSON yolu (ranked token doğrulama)
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-admin.json
# FIREBASE_PROJECT_ID=pucket-9413c
RECONNECT_GRACE_MS=60000
GUEST_RANKED=false
# Admin paneli (/admin) — kullanıcı: admin
# ADMIN_PASSWORD=guclu-bir-sifre
